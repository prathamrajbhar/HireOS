datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  HR
  CANDIDATE
}

enum JobStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum ApplicationStatus {
  SOURCED
  SCREENED
  ASSESSMENT
  INTERVIEWED
  HR_ROUND
  DECIDED
  OFFERED
  ACCEPTED
  REJECTED
}

enum HRRoundStatus {
  PENDING
  SCHEDULED
  PASSED
  FAILED
}

enum DecisionOutcome {
  HIRE
  REJECT
  HOLD
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  passwordHash     String            @map("password_hash")
  role             Role              @default(CANDIDATE)
  orgId            String?           @map("org_id")
  createdAt        DateTime          @default(now()) @map("created_at")
  organization     Organization?     @relation(fields: [orgId], references: [id])
  candidateProfile CandidateProfile?

  @@map("users")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  logoUrl   String?  @map("logo_url")
  industry  String?
  size      String?
  settings  Json?
  createdAt DateTime @default(now()) @map("created_at")
  users     User[]
  jobs      Job[]

  @@map("organizations")
}

model Job {
  id               String        @id @default(uuid())
  orgId            String        @map("org_id")
  title            String
  description      String
  rubric           Json
  thresholds       Json
  status           JobStatus     @default(DRAFT)
  createdAt        DateTime      @default(now()) @map("created_at")
  organization     Organization  @relation(fields: [orgId], references: [id])
  applications     Application[]

  @@map("jobs")
}

model CandidateProfile {
  id                String        @id @default(uuid())
  userId            String        @unique @map("user_id")
  resumeUrl         String?       @map("resume_url")
  linkedinUrl       String?       @map("linkedin_url")
  githubUrl         String?       @map("github_url")
  skills            Json
  targetRoles       Json          @map("target_roles")
  expectedSalary    String?       @map("expected_salary")
  noticePeriod      String?       @map("notice_period")
  workAuthorization String?       @map("work_authorization")
  proudProject      String?       @map("proud_project")
  workValues        Json?         @map("work_values")
  createdAt         DateTime      @default(now()) @map("created_at")
  user              User          @relation(fields: [userId], references: [id])
  applications      Application[]

  @@map("candidate_profiles")
}

model Application {
  id                 String            @id @default(uuid())
  candidateId        String            @map("candidate_id")
  jobId              String            @map("job_id")
  status             ApplicationStatus @default(SOURCED)
  hrRoundStatus      HRRoundStatus?    @default(PENDING) @map("hr_round_status")
  hrRoundScheduledAt DateTime?         @map("hr_round_scheduled_at")
  hrRoundCompletedAt DateTime?         @map("hr_round_completed_at")
  appliedAt          DateTime          @default(now()) @map("applied_at")

  candidateCandidate CandidateProfile  @relation(fields: [candidateId], references: [id])
  job                Job               @relation(fields: [jobId], references: [id])
  evaluations        Evaluation[]
  interviews         Interview[]
  assessments        Assessment[]
  codingSubmissions  CodingSubmission[]
  offers             Offer[]

  @@map("applications")
}

model Evaluation {
  id             String           @id @default(uuid())
  applicationId  String           @map("application_id")
  stage          String
  resumeScore    Int?             @map("resume_score")
  interviewScore Int?             @map("interview_score")
  compositeScore Int              @map("composite_score")
  biasFlag       Boolean          @default(false) @map("bias_flag")
  biasReport     Json?            @map("bias_report")
  decision       DecisionOutcome
  reasoning      String
  createdAt      DateTime         @default(now()) @map("created_at")

  application    Application      @relation(fields: [applicationId], references: [id])

  @@map("evaluations")
}

model Interview {
  id               String       @id @default(uuid())
  applicationId    String       @map("application_id")
  scheduledAt      DateTime?    @map("scheduled_at")
  transcript       Json?
  audioUrl         String?      @map("audio_url")
  proctorFlags     Json?        @map("proctor_flags")
  engagementSignal Json?        @map("engagement_signal")
  videoConsent     Boolean      @default(false) @map("video_consent")
  status           String       @default("scheduled")

  application      Application  @relation(fields: [applicationId], references: [id])

  @@map("interviews")
}

model Assessment {
  id            String      @id @default(uuid())
  applicationId String      @map("application_id")
  testType      String      @map("test_type")
  questions     Json
  responses     Json?
  score         Int?
  status        String      @default("pending")

  application   Application @relation(fields: [applicationId], references: [id])

  @@map("assessments")
}

model CodingSubmission {
  id             String      @id @default(uuid())
  applicationId  String      @map("application_id")
  language       String
  code           String
  testResults    Json?       @map("test_results")
  passRate       Float?      @map("pass_rate")
  executionTime  Int?        @map("execution_time_ms")

  application    Application @relation(fields: [applicationId], references: [id])

  @@map("coding_submissions")
}

model Offer {
  id            String      @id @default(uuid())
  applicationId String      @map("application_id")
  roleTitle     String      @map("role_title")
  salary        String
  equity        String?
  startDate     String?     @map("start_date")
  status        String      @default("pending")
  signatureSvg  String?     @map("signature_svg")
  validUntil    DateTime?   @map("valid_until")

  application   Application @relation(fields: [applicationId], references: [id])

  @@map("offers")
}

model AgentLog {
  id        String   @id @default(uuid())
  jobId     String?  @map("job_id")
  agentName String   @map("agent_name")
  action    String
  input     Json?
  output    Json?
  status    String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("agent_logs")
}

model MockSession {
  id            String   @id @default(uuid())
  candidateId   String   @map("candidate_id")
  targetCompany String   @map("target_company")
  targetRole    String   @map("target_role")
  rubric        Json
  transcript    Json?
  score         Int?
  feedback      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("mock_sessions")
}

model PrepContent {
  id            String   @id @default(uuid())
  companyName   String   @map("company_name")
  roleArchetype String   @map("role_archetype")
  questions     Json
  cultureNotes  String?  @map("culture_notes")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("prep_contents")
}
